<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Agent Manager | Professional Edition</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --rd-blue: #0d6efd;
            --rd-blue-hover: #0a58ca;
            --rd-bg-light: #f8f9fa;
            --rd-bg-white: #ffffff;
            --rd-text-dark: #1e1e1e;
            --rd-text-muted: #666666;
            --rd-border: #e0e0e0;
            --rd-header-bg: #ffffff;
            --rd-success: #198754;
            --rd-terminal-bg: #1e1e1e;
            --rd-terminal-dark: #0d1117;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--rd-bg-white);
            color: var(--rd-text-dark);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        /* ===== TOP ANNOUNCEMENT BANNER ===== */
        .top-banner {
            background-color: #f0f4f8;
            border-bottom: 1px solid var(--rd-border);
            padding: 10px 20px;
            text-align: center;
            font-size: 0.85rem;
            color: var(--rd-text-dark);
        }

        .top-banner span {
            font-weight: 700;
        }

        /* ===== HEADER / NAVBAR ===== */
        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 5%;
            height: 75px;
            background: var(--rd-header-bg);
            border-bottom: 1px solid var(--rd-border);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .header-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 800;
            font-size: 1.3rem;
            color: var(--rd-text-dark);
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        .header-logo svg {
            color: var(--rd-blue);
        }

        .nav-links {
            display: flex;
            gap: 24px;
            align-items: center;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--rd-text-dark);
            font-size: 0.95rem;
            font-weight: 500;
            transition: color 0.2s;
        }

        .nav-links a:hover {
            color: var(--rd-blue);
        }

        .btn-header-download {
            border: 1px solid var(--rd-border);
            padding: 8px 24px;
            border-radius: 50px;
            font-weight: 600;
            color: var(--rd-text-dark);
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.2s;
        }

        .btn-header-download:hover {
            background: var(--rd-bg-light);
            border-color: var(--rd-blue);
        }

        /* ===== HERO SECTION ===== */
        .hero {
            text-align: center;
            padding: 70px 20px 50px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .hero h1 {
            font-size: 3.8rem;
            font-weight: 900;
            letter-spacing: -2.5px;
            line-height: 1;
            margin-bottom: 24px;
            color: #111;
        }

        .hero p {
            font-size: 1.25rem;
            color: var(--rd-text-muted);
            max-width: 750px;
            margin: 0 auto 40px;
            font-weight: 400;
        }

        /* ===== TABS ===== */
        .tabs-container {
            border-top: 1px solid var(--rd-border);
            padding: 0 5%;
            background: #ffffff;
            position: sticky;
            top: 75px;
            z-index: 999;
        }

        .tabs {
            display: flex;
            gap: 40px;
            justify-content: center;
            overflow-x: auto;
        }

        .tab {
            padding: 20px 0;
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--rd-text-muted);
            cursor: pointer;
            position: relative;
            transition: color 0.2s;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .tab svg {
            width: 18px;
            height: 18px;
            stroke-width: 2.2;
        }

        .tab:hover {
            color: var(--rd-text-dark);
        }

        .tab.active {
            color: var(--rd-blue);
        }

        .tab.active svg {
            color: var(--rd-blue);
        }

        .tab.active::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--rd-blue);
        }

        /* ===== CONTENT AREAS ===== */
        .main-content {
            background-color: #fcfcfc;
            padding: 50px 5%;
            min-height: 600px;
        }

        .page-content {
            display: none;
        }

        .page-content.active {
            display: block;
            animation: fadeIn 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(15px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .section-title {
            font-size: 2.2rem;
            font-weight: 900;
            letter-spacing: -1px;
            margin-bottom: 12px;
            text-align: center;
        }

        .section-subtitle {
            font-size: 1rem;
            color: var(--rd-text-muted);
            text-align: center;
            margin-bottom: 45px;
        }

        /* ===== BUTTONS ===== */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 14px 35px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
            border: 1px solid transparent;
            gap: 10px;
        }

        .btn-primary {
            background-color: var(--rd-blue);
            color: #ffffff;
            border: none;
        }

        .btn-primary:hover {
            background-color: var(--rd-blue-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
        }

        .btn-primary:disabled {
            background-color: #ccc;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
        }

        .btn-outline {
            background-color: transparent;
            border: 1px solid var(--rd-border);
            color: var(--rd-text-dark);
        }

        .btn-outline:hover {
            background-color: var(--rd-bg-light);
            border-color: var(--rd-text-muted);
        }

        /* ===== DOMAIN CARDS ===== */
        .domain-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 24px;
            max-width: 1200px;
            margin: 0 auto 40px;
        }

        .domain-card {
            background: #ffffff;
            border: 1px solid var(--rd-border);
            border-radius: 20px;
            padding: 35px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
            text-align: left;
            position: relative;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .domain-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
            border-color: var(--rd-blue);
        }

        .domain-card .icon-container {
            width: 50px;
            height: 50px;
            background: var(--rd-bg-light);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--rd-blue);
            margin-bottom: 5px;
            transition: all 0.3s;
            font-size: 1.5rem;
        }

        .domain-card:hover .icon-container {
            background: var(--rd-blue);
            color: white;
        }

        .domain-card.selected {
            border-color: var(--rd-blue);
            background: #f0f7ff;
        }

        .domain-card.selected .icon-container {
            background: var(--rd-blue);
            color: white;
        }

        .domain-name {
            font-size: 1.4rem;
            font-weight: 800;
            color: #111;
            letter-spacing: -0.5px;
        }

        .domain-desc {
            font-size: 0.95rem;
            color: var(--rd-text-muted);
            line-height: 1.6;
        }

        .domain-meta {
            margin-top: auto;
            font-size: 0.8rem;
            font-weight: 600;
            color: #999;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        /* ===== BUILDER / CARD UI ===== */
        .builder-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .card {
            background: #fff;
            border: 1px solid var(--rd-border);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .card-header {
            padding: 18px 24px;
            font-weight: 700;
            border-bottom: 1px solid var(--rd-border);
            background: var(--rd-bg-light);
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .card-body {
            padding: 24px;
        }

        /* ===== CHIPS ===== */
        .agent-chip {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px;
            border: 1px solid var(--rd-border);
            border-radius: 14px;
            margin-bottom: 12px;
            transition: all 0.2s;
        }

        .agent-chip:hover {
            border-color: var(--rd-blue);
            background: #fcfdfe;
        }

        .agent-chip.in-team {
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        /* ===== LOGS WINDOW ===== */
        .app-window {
            background: var(--rd-terminal-dark);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.25);
            max-width: 1000px;
            margin: 20px auto;
            border: 1px solid #30363d;
        }

        .app-header {
            background: #161b22;
            padding: 14px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            color: #8b949e;
            font-size: 0.75rem;
            border-bottom: 1px solid #30363d;
        }

        .app-body {
            padding: 25px;
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
            font-size: 0.85rem;
            color: #e6edf3;
            min-height: 450px;
            max-height: 550px;
            overflow-y: auto;
            line-height: 1.7;
        }

        .log-line {
            margin-bottom: 8px;
        }

        .log-line .highlight {
            color: #58a6ff;
            font-weight: 600;
        }

        .log-line .time {
            color: #484f58;
            margin-right: 12px;
        }

        .log-line.error .message {
            color: #fca5a5;
        }

        .log-line.success .message {
            color: #7ee787;
        }

        /* ===== COST CARDS ===== */
        .cost-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .cost-card {
            background: #fff;
            padding: 24px;
            border-radius: 16px;
            border: 1px solid var(--rd-border);
            text-align: center;
            transition: transform 0.2s;
        }

        .cost-card:hover {
            transform: translateY(-3px);
        }

        .cost-label {
            font-size: 0.75rem;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
        }

        .cost-value {
            font-size: 2rem;
            font-weight: 800;
            margin-top: 8px;
            letter-spacing: -1px;
        }

        .cost-value.green {
            color: #198754;
        }

        .cost-value.blue {
            color: #0d6efd;
        }

        .cost-value.purple {
            color: #7048e8;
        }

        /* ===== MODAL ===== */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(5px);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }

        /* ===== NOTIFICATIONS ===== */
        #notification-container {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 3000;
            display: flex;
            flex-direction: column;
            gap: 10px;
            pointer-events: none;
            width: 100%;
            max-width: 400px;
        }

        .notification-toast {
            background: #ffffff;
            border-left: 5px solid var(--rd-blue);
            padding: 15px 25px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
            display: flex;
            align-items: center;
            gap: 15px;
            pointer-events: auto;
            animation: slideInDown 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            transition: all 0.3s ease;
            position: relative;
        }

        .notification-toast.error {
            border-left-color: #dc3545;
        }

        .notification-toast.success {
            border-left-color: var(--rd-success);
        }

        .notification-toast.warning {
            border-left-color: #ffc107;
        }

        .notification-toast .icon {
            font-size: 1.2rem;
        }

        .notification-toast .message {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--rd-text-dark);
            flex: 1;
        }

        .notification-toast .close-btn {
            cursor: pointer;
            color: #ccc;
            font-size: 1rem;
            transition: color 0.2s;
        }

        .notification-toast .close-btn:hover {
            color: #888;
        }

        @keyframes slideInDown {
            from {
                transform: translateY(-50px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        @keyframes fadeOutUp {
            from {
                transform: translateY(0);
                opacity: 1;
            }

            to {
                transform: translateY(-20px);
                opacity: 0;
            }
        }

        /* ===== PROJECTS PAGE ===== */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 24px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .project-card {
            background: #fff;
            border: 1px solid var(--rd-border);
            border-radius: 20px;
            padding: 28px;
            transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .project-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #0d6efd, #6610f2);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .project-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.12);
            border-color: var(--rd-blue);
        }

        .project-card:hover::before {
            opacity: 1;
        }

        .project-card .proj-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .project-card .proj-name {
            font-size: 1.25rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            color: #111;
        }

        .project-card .proj-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .proj-badge.fullstack {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .proj-badge.frontend {
            background: #fce7f3;
            color: #be185d;
        }

        .proj-badge.backend {
            background: #d1fae5;
            color: #065f46;
        }

        .proj-badge.static {
            background: #fef3c7;
            color: #92400e;
        }

        .proj-badge.other {
            background: #f3f4f6;
            color: #374151;
        }

        .project-card .proj-files {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 16px;
        }

        .proj-file-chip {
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 600;
            background: #f1f5f9;
            color: #475569;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .proj-file-chip .dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            display: inline-block;
        }

        .dot.python {
            background: #3572A5;
        }

        .dot.javascript,
        .dot.jsx {
            background: #f1e05a;
        }

        .dot.typescript,
        .dot.tsx {
            background: #2b7489;
        }

        .dot.html {
            background: #e34c26;
        }

        .dot.css {
            background: #563d7c;
        }

        .dot.json {
            background: #292929;
        }

        .dot.markdown {
            background: #083fa1;
        }

        .dot.text {
            background: #999;
        }

        .project-card .proj-meta {
            display: flex;
            align-items: center;
            gap: 18px;
            font-size: 0.8rem;
            color: #94a3b8;
            font-weight: 600;
        }

        .project-card .proj-actions {
            display: flex;
            gap: 8px;
            margin-top: 18px;
        }

        .proj-actions .btn-proj {
            flex: 1;
            padding: 10px 16px;
            border-radius: 12px;
            border: 1px solid var(--rd-border);
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            background: #fff;
            color: var(--rd-text-dark);
        }

        .proj-actions .btn-proj:hover {
            background: var(--rd-bg-light);
            border-color: var(--rd-blue);
            color: var(--rd-blue);
        }

        .proj-actions .btn-proj.primary {
            background: var(--rd-blue);
            color: #fff;
            border-color: var(--rd-blue);
        }

        .proj-actions .btn-proj.primary:hover {
            background: var(--rd-blue-hover);
        }

        /* Project Detail Panel */
        .proj-detail-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(4px);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }

        .proj-detail-overlay.active {
            display: flex;
        }

        .proj-detail-panel {
            background: #fff;
            border-radius: 20px;
            width: 95%;
            max-width: 1200px;
            height: 85vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.3);
        }

        .proj-detail-header {
            padding: 20px 28px;
            border-bottom: 1px solid var(--rd-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .proj-detail-header h3 {
            font-size: 1.3rem;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .proj-detail-body {
            display: grid;
            grid-template-columns: 260px 1fr;
            flex: 1;
            overflow: hidden;
        }

        .proj-file-list {
            border-right: 1px solid var(--rd-border);
            overflow-y: auto;
            background: #fafbfc;
        }

        .proj-file-item {
            padding: 12px 20px;
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.15s;
            border-bottom: 1px solid #f1f5f9;
        }

        .proj-file-item:hover {
            background: #eef2ff;
        }

        .proj-file-item.active {
            background: #dbeafe;
            color: var(--rd-blue);
            font-weight: 700;
        }

        .proj-file-item .file-size {
            margin-left: auto;
            font-size: 0.7rem;
            color: #94a3b8;
        }

        .proj-preview-area {
            flex: 1;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .proj-preview-tabs {
            display: flex;
            border-bottom: 1px solid var(--rd-border);
            background: #fafbfc;
        }

        .proj-preview-tab {
            padding: 10px 20px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            border-bottom: 2px solid transparent;
            transition: all 0.2s;
            color: var(--rd-text-muted);
        }

        .proj-preview-tab:hover {
            color: var(--rd-text-dark);
        }

        .proj-preview-tab.active {
            color: var(--rd-blue);
            border-bottom-color: var(--rd-blue);
        }

        .proj-preview-content {
            flex: 1;
            overflow: hidden;
        }

        .proj-preview-content iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

        .proj-preview-content pre {
            height: 100%;
            overflow: auto;
            margin: 0;
            padding: 20px;
            background: #1e1e1e;
            color: #d4d4d4;
            font-family: 'SFMono-Regular', Consolas, monospace;
            font-size: 0.85rem;
            line-height: 1.7;
        }

        @media (max-width: 900px) {
            .hero h1 {
                font-size: 2.8rem;
                letter-spacing: -1.5px;
            }

            .builder-layout,
            .cost-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>

    <!-- SVG ICON SPRITE -->
    <svg style="display: none;">
        <symbol id="icon-domain" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="3" y1="9" x2="21" y2="9"></line>
            <line x1="9" y1="21" x2="9" y2="9"></line>
        </symbol>
        <symbol id="icon-builder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path
                d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z">
            </path>
        </symbol>
        <symbol id="icon-monitor" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="20" x2="18" y2="10"></line>
            <line x1="12" y1="20" x2="12" y2="4"></line>
            <line x1="6" y1="20" x2="6" y2="14"></line>
        </symbol>
        <symbol id="icon-reports" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
        </symbol>
        <symbol id="icon-costs" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="1" x2="12" y2="23"></line>
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
        </symbol>
        <symbol id="icon-results" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
        </symbol>
        <symbol id="icon-training" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
        </symbol>
        <!-- Domain Specific Icons -->
        <symbol id="d-soft" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
        </symbol>
        <symbol id="d-mkt" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path>
            <path d="M22 12A10 10 0 0 0 12 2v10z"></path>
        </symbol>
        <symbol id="d-ops" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
            <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
            <line x1="6" y1="6" x2="6.01" y2="6"></line>
            <line x1="6" y1="18" x2="6.01" y2="18"></line>
        </symbol>
    </svg>

    <!-- NOTIFICATION CONTAINER -->
    <div id="notification-container"></div>
    <!-- HEADER -->
    <header class="header">
        <a href="#" class="header-logo" onclick="location.reload()">
            <svg width="34" height="34" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path
                    d="M20 50C20 33.4315 33.4315 20 50 20C66.5685 20 80 33.4315 80 50C80 66.5685 66.5685 80 50 80C33.4315 80 20 66.5685 20 50Z"
                    stroke="currentColor" stroke-width="12" />
                <path d="M50 35L65 50L50 65L35 50L50 35Z" fill="currentColor" />
            </svg>
            AI Agent Manager
        </a>
        <nav class="nav-links">
            <a href="#" id="header-status">Bağlantı Bekleniyor...</a>
            <a href="#" class="btn-header-download">DashBoard</a>
        </nav>
    </header>

    <!-- HERO SECTION -->
    <section class="hero" id="dashboard-hero">
        <h1>Otonom Ajan Yönetimi.</h1>
        <p>İş süreçlerinizi otonom ajanlara devredin. Karmaşık operasyonel akışları, raporlama motorlarını ve geliştirme
            fazlarını tek bir terminalden kontrol edin.</p>
        <div class="hero-actions">
            <button class="btn btn-primary" onclick="switchTab('reports')">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
                Hızlı Rapor Başlat
            </button>
        </div>
    </section>

    <!-- TABS -->
    <div class="tabs-container">
        <div class="tabs">
            <div class="tab active" id="tab-domains" onclick="switchTab('domains')"><svg>
                    <use href="#icon-domain" />
                </svg> İş Alanları</div>
            <div class="tab" id="tab-builder" onclick="switchTab('builder')"><svg>
                    <use href="#icon-builder" />
                </svg> Takım</div>
            <div class="tab" id="tab-monitor" onclick="switchTab('monitor')"><svg>
                    <use href="#icon-monitor" />
                </svg> İzleme</div>
            <div class="tab" id="tab-reports" onclick="switchTab('reports')"><svg>
                    <use href="#icon-reports" />
                </svg> Raporlar</div>
            <div class="tab" id="tab-costs" onclick="switchTab('costs')"><svg>
                    <use href="#icon-costs" />
                </svg> Maliyet</div>
            <div class="tab" id="tab-results" onclick="switchTab('results')"><svg>
                    <use href="#icon-results" />
                </svg> Sonuçlar</div>
            <div class="tab" id="tab-training" onclick="switchTab('training')"><svg>
                    <use href="#icon-training" />
                </svg> Learning Center</div>
            <div class="tab" id="tab-skills" onclick="switchTab('skills')"><svg>
                    <use href="#icon-training" />
                </svg> Skill Yönetimi</div>
            <div class="tab" id="tab-performance" onclick="switchTab('performance')"><svg>
                    <use href="#icon-costs" />
                </svg> Performans</div>
            <div class="tab" id="tab-projects" onclick="switchTab('projects')"><svg>
                    <use href="#icon-results" />
                </svg> Projeler</div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="main-content">

        <!-- PAGE: DOMAINS -->
        <div id="page-domains" class="page-content active">
            <h2 class="section-title">İş Alanınızı Seçin</h2>
            <p class="section-subtitle">Ajan havuzunu konfigüre etmek için uzmanlık alanı belirleyin.</p>
            <div class="domain-grid" id="domain-grid">
                <!-- JS populated -->
            </div>
            <div style="text-align:center;">
                <button class="btn btn-primary" id="btn-select-domain" disabled onclick="selectDomain()">Takımı
                    Yapılandır →</button>
            </div>
        </div>

        <!-- PAGE: BUILDER -->
        <div id="page-builder" class="page-content">
            <h2 class="section-title" id="builder-title">Takımı Yapılandır</h2>
            <p class="section-subtitle" id="builder-subtitle">Görev aşamalarını ve çalışacak ajanları belirleyin.</p>

            <div class="builder-layout">
                <div class="card">
                    <div class="card-header">Ajan Havuzu</div>
                    <div class="card-body" id="agent-pool"></div>
                </div>
                <div class="card">
                    <div class="card-header">
                        <span>Aktif Takım</span>
                        <span id="summary-cost" style="font-size:0.8rem; color:var(--rd-blue);">$0/saat</span>
                    </div>
                    <div class="card-body">
                        <input type="text" id="team-name" placeholder="Takım Adı..."
                            style="width:100%; padding:10px; border-radius:8px; border:1px solid #ddd; margin-bottom:15px;">
                        <div id="team-lineup"></div>
                        <button class="btn btn-primary" id="btn-create-team" onclick="createTeam()"
                            style="width:100%; margin-top:15px;">Takımı Kaydet</button>
                    </div>
                </div>
            </div>

            <div id="task-runner-section"
                style="display:none; margin-top:30px; max-width:1200px; margin-left:auto; margin-right:auto;">
                <div class="card">
                    <div class="card-header">🚀 Görev Ata</div>
                    <div class="card-body">
                        <textarea id="task-input" placeholder="Görevi buraya yazın..."
                            style="width:100%; height:100px; padding:15px; border-radius:10px; border:1px solid #ddd;"></textarea>
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:15px;">
                            <span id="run-status" style="font-size:0.85rem;"></span>
                            <button class="btn btn-primary" id="btn-run-task" onclick="runTask()">Görevi Başlat</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PAGE: MONITORING -->
        <div id="page-monitor" class="page-content">
            <div style="max-width:1000px; margin:0 auto;">
                <h2 class="section-title">Canlı İzleme</h2>
                <div style="display:flex; gap:10px; margin-bottom:20px; justify-content:center;">
                    <div
                        style="padding:10px 20px; background:#fff; border-radius:10px; border:1px solid #eee; text-align:center;">
                        <div style="font-size:0.7rem; color:#888;">AKTİF AGENT</div>
                        <div id="m-agent" style="font-weight:700;">Idle</div>
                    </div>
                    <div
                        style="padding:10px 20px; background:#fff; border-radius:10px; border:1px solid #eee; text-align:center;">
                        <div style="font-size:0.7rem; color:#888;">GÖREV</div>
                        <div id="m-task" style="font-weight:700;">-</div>
                    </div>
                </div>

                <div class="app-window">
                    <div class="app-header">
                        <div class="app-dots">
                            <div class="dot red"></div>
                            <div class="dot yellow"></div>
                            <div class="dot green"></div>
                        </div>
                        <div>manager@agent-os: ~ / logs</div>
                        <div id="pulse-indicator" class="dot green" style="width:8px; height:8px;"></div>
                    </div>
                    <div class="app-body" id="log-window">
                        <!-- Logs here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- PAGE: REPORTS -->
        <div id="page-reports" class="page-content">
            <h2 class="section-title">Berqun Raporları</h2>
            <p class="section-subtitle">Aylık & haftalık verimlilik raporlarını tetikleyin, trendleri izleyin ve
                yönetici özetleri alın.</p>

            <!-- ===== REPORT SUB-TABS ===== -->
            <div style="display:flex; gap:8px; justify-content:center; margin-bottom:30px; flex-wrap:wrap;">
                <button class="btn btn-outline" id="rtab-monthly" onclick="switchReportView('monthly')"
                    style="padding:10px 24px; border-radius:50px; font-weight:600; font-size:0.85rem;">📅 Aylık
                    Rapor</button>
                <button class="btn btn-primary" id="rtab-weekly" onclick="switchReportView('weekly')"
                    style="padding:10px 24px; border-radius:50px; font-weight:600; font-size:0.85rem;">📊 Haftalık
                    Raporlar</button>
                <button class="btn btn-outline" id="rtab-trends" onclick="switchReportView('trends')"
                    style="padding:10px 24px; border-radius:50px; font-weight:600; font-size:0.85rem;">📈 BQ
                    Trendleri</button>
                <button class="btn btn-outline" id="rtab-ai" onclick="switchReportView('ai')"
                    style="padding:10px 24px; border-radius:50px; font-weight:600; font-size:0.85rem;">🤖 AI
                    Özet</button>
                <button class="btn btn-outline" id="rtab-notify" onclick="switchReportView('notify')"
                    style="padding:10px 24px; border-radius:50px; font-weight:600; font-size:0.85rem;">🔔
                    Bildirimler</button>
            </div>

            <!-- ===== 1. AYLIK RAPOR (Mevcut Sistem) ===== -->
            <div id="rview-monthly" style="display:none;">
                <div class="card" style="max-width:900px; margin:0 auto;">
                    <div class="card-header">📅 Aylık Domain Raporu</div>
                    <div class="card-body">
                        <div class="report-form">
                            <div style="display:flex; gap:15px;">
                                <div class="form-group" style="flex:1;">
                                    <label class="form-label">Ay</label>
                                    <select id="report-month-select" onchange="updateReportDates()"
                                        class="select-input">
                                        <option value="1">Ocak</option>
                                        <option value="2">Şubat</option>
                                        <option value="3">Mart</option>
                                        <option value="4">Nisan</option>
                                        <option value="5">Mayıs</option>
                                        <option value="6">Haziran</option>
                                        <option value="7">Temmuz</option>
                                        <option value="8">Ağustos</option>
                                        <option value="9">Eylül</option>
                                        <option value="10">Ekim</option>
                                        <option value="11">Kasım</option>
                                        <option value="12">Aralık</option>
                                    </select>
                                </div>
                                <div class="form-group" style="width:120px;">
                                    <label class="form-label">Yıl</label>
                                    <select id="report-year-select" onchange="updateReportDates()" class="select-input">
                                        <option value="2025">2025</option>
                                        <option value="2026" selected>2026</option>
                                        <option value="2027">2027</option>
                                    </select>
                                </div>
                                <div id="date-preview"
                                    style="align-self:end; padding:10px; font-size:0.8rem; color:var(--rd-blue);"></div>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Domain Seçimi</label>
                                <div id="report-domain-list" class="domain-list"></div>
                                <div style="margin-top:10px; display:flex; gap:10px;">
                                    <button class="btn btn-outline" onclick="toggleReportDomains(true)"
                                        style="padding:6px 15px; font-size:0.8rem;">Tümünü Seç</button>
                                    <button class="btn btn-outline" onclick="toggleReportDomains(false)"
                                        style="padding:6px 15px; font-size:0.8rem;">Temizle</button>
                                </div>
                            </div>

                            <button class="btn btn-primary" onclick="runBatchReports()"
                                style="height:50px; font-size:1.1rem;">🚀 Raporu Başlat ve Mail Gönder</button>
                        </div>

                        <div id="report-monitor" style="margin-top:30px;">
                            <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
                                <span style="font-weight:700; font-size:0.9rem;">İşlem Takibi</span>
                                <span id="report-status-badge" style="font-size:0.75rem; color:#888;">Beklemede</span>
                            </div>
                            <pre id="report-logs"
                                style="background:#1e1e1e; color:#86efac; padding:15px; border-radius:10px; font-size:0.8rem; height:200px; overflow-y:auto; font-family:monospace;"></pre>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== 2. HAFTALIK POS RAPORU ===== -->
            <div id="rview-weekly" style="display:block;">
                <div style="max-width:1100px; margin:0 auto;">
                    <!-- KPI Cards -->
                    <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:15px; margin-bottom:25px;"
                        id="weekly-kpi-cards">
                        <div class="cost-card" style="border-left:4px solid #2563eb;">
                            <div class="cost-label">RAPOR TİPİ</div>
                            <div class="cost-value blue" style="font-size:1.3rem;">Haftalık Raporlar</div>
                        </div>
                        <div class="cost-card" style="border-left:4px solid #16a34a;">
                            <div class="cost-label">KAPSAM</div>
                            <div class="cost-value green" style="font-size:1.3rem;">Soft + Android</div>
                        </div>
                        <div class="cost-card" style="border-left:4px solid #7c3aed;">
                            <div class="cost-label">RAPOR SAYISI</div>
                            <div class="cost-value purple" style="font-size:1.3rem;">5 Kategori</div>
                        </div>
                        <div class="cost-card" style="border-left:4px solid #ea580c;">
                            <div class="cost-label">ÇIKTI</div>
                            <div class="cost-value" style="font-size:1.3rem; color:#ea580c;">ZIP + Mail</div>
                        </div>
                    </div>

                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
                        <!-- Tetikleme Formu -->
                        <div class="card">
                            <div class="card-header">🚀 Haftalık Raporu Tetikle</div>
                            <div class="card-body">
                                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px;">
                                    <div>
                                        <label
                                            style="font-size:0.8rem; font-weight:600; color:#666; display:block; margin-bottom:6px;">Hafta
                                            Başlangıcı</label>
                                        <input type="date" id="wp-start"
                                            style="width:100%; padding:10px; border-radius:10px; border:1px solid #ddd; font-size:0.9rem;">
                                    </div>
                                    <div>
                                        <label
                                            style="font-size:0.8rem; font-weight:600; color:#666; display:block; margin-bottom:6px;">Hafta
                                            Bitişi</label>
                                        <input type="date" id="wp-end"
                                            style="width:100%; padding:10px; border-radius:10px; border:1px solid #ddd; font-size:0.9rem;">
                                    </div>
                                </div>

                                <div style="margin-bottom:16px;">
                                    <label
                                        style="font-size:0.8rem; font-weight:600; color:#666; display:block; margin-bottom:6px;">Ekip
                                        Seçimi</label>
                                    <select id="wp-team"
                                        style="width:100%; padding:10px; border-radius:10px; border:1px solid #ddd; font-size:0.9rem; background:#fff; cursor:pointer;">
                                        <option value="">🏢 Tüm Ekipler</option>
                                        <option value="Soft POS">📱 Soft POS (10 kişi)</option>
                                        <option value="Android POS">📲 Android POS (5 kişi)</option>
                                        <option value="Temel Bankacilik - Belkay Saratas">🏦 Temel Bankacılık - Belkay
                                            Sarataş</option>
                                        <option value="Temel Bankacilik - Mustafa Yildirim">🏦 Temel Bankacılık -
                                            Mustafa Yıldırım (18 kişi)</option>
                                    </select>
                                </div>

                                <div style="display:flex; gap:12px; margin-bottom:20px;">
                                    <label
                                        style="display:flex; align-items:center; gap:6px; font-size:0.85rem; cursor:pointer;">
                                        <input type="checkbox" id="wp-nomail"> Mail gönderme
                                    </label>
                                </div>

                                <button class="btn btn-primary" onclick="runWeeklyPOS()" id="btn-run-weekly"
                                    style="width:100%; height:48px; font-size:1rem; border-radius:12px;">
                                    📊 Haftalık Raporu Başlat
                                </button>

                                <div
                                    style="margin-top:15px; padding:12px; background:#f0fdf4; border:1px solid #86efac; border-radius:10px; font-size:0.8rem; color:#166534;">
                                    <strong>📂 Oluşturulacak Raporlar:</strong><br>
                                    • Çalışan Faaliyetleri (kişisel Excel)<br>
                                    • Çalışan Verimliliği (takım özet)<br>
                                    • 100 Puan Altı BQ Çalışanlar<br>
                                    • 3 Gün VPN Yapmayanlar<br>
                                    • Verimsiz Aktiviteler
                                </div>
                            </div>
                        </div>

                        <!-- Canlı Log -->
                        <div class="card">
                            <div class="card-header">
                                <span>📡 Canlı İşlem Takibi</span>
                                <span id="wp-status-indicator"
                                    style="font-size:0.75rem; padding:4px 12px; border-radius:20px; background:#f1f5f9; color:#64748b; font-weight:600;">Beklemede</span>
                            </div>
                            <div class="card-body" style="padding:0;">
                                <pre id="wp-live-logs"
                                    style="background:#0f172a; color:#86efac; padding:18px; font-size:0.78rem; height:370px; overflow-y:auto; font-family:'SFMono-Regular', Consolas, monospace; margin:0; border-radius:0 0 16px 16px; line-height:1.6;">Rapor çalıştırıldığında loglar burada görünecek...</pre>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== 3. BQ TRENDLERİ ===== -->
            <div id="rview-trends" style="display:none;">
                <div style="max-width:1100px; margin:0 auto;">
                    <div style="text-align:center; margin-bottom:25px;">
                        <button class="btn btn-primary" onclick="loadBQTrends()"
                            style="padding:10px 30px; border-radius:50px;">
                            📈 BQ Trendlerini Yükle
                        </button>
                    </div>

                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:25px;">
                        <!-- En Çok Gelişenler -->
                        <div class="card">
                            <div class="card-header" style="color:#16a34a;">🚀 En Çok Gelişenler (TOP 5)</div>
                            <div class="card-body" id="bq-improving" style="min-height:200px;">
                                <div style="text-align:center; padding:40px; color:#94a3b8;">Henüz yüklenmedi</div>
                            </div>
                        </div>

                        <!-- En Çok Gerileyenler -->
                        <div class="card">
                            <div class="card-header" style="color:#dc2626;">⚠️ En Çok Gerileyenler (TOP 5)</div>
                            <div class="card-body" id="bq-declining" style="min-height:200px;">
                                <div style="text-align:center; padding:40px; color:#94a3b8;">Henüz yüklenmedi</div>
                            </div>
                        </div>
                    </div>

                    <!-- Tüm Personel BQ Tablosu -->
                    <div class="card">
                        <div class="card-header">
                            <span>📊 Haftalık BQ Karşılaştırma Tablosu</span>
                            <span id="bq-total-badge" style="font-size:0.75rem; color:#888;"></span>
                        </div>
                        <div class="card-body" style="overflow-x:auto;">
                            <table style="width:100%; border-collapse:collapse; font-size:0.85rem;" id="bq-trend-table">
                                <thead>
                                    <tr style="border-bottom:2px solid #e2e8f0; text-align:left;">
                                        <th style="padding:10px;">Ad Soyad</th>
                                        <th style="padding:10px;">Takım</th>
                                        <th style="padding:10px; text-align:center;">Hafta 1</th>
                                        <th style="padding:10px; text-align:center;">Hafta 2</th>
                                        <th style="padding:10px; text-align:center;">Hafta 3</th>
                                        <th style="padding:10px; text-align:center;">Hafta 4</th>
                                        <th style="padding:10px; text-align:center;">Değişim</th>
                                        <th style="padding:10px;">Trend</th>
                                    </tr>
                                </thead>
                                <tbody id="bq-trend-body">
                                    <tr>
                                        <td colspan="8" style="text-align:center; padding:40px; color:#94a3b8;">Veri
                                            yüklemek için yukarıdaki butonu kullanın</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== 4. AI ÖZET ===== -->
            <div id="rview-ai" style="display:none;">
                <div style="max-width:900px; margin:0 auto;">
                    <div class="card" style="margin-bottom:20px;">
                        <div class="card-header">🤖 AI Yönetici Özeti Oluştur</div>
                        <div class="card-body">
                            <div style="display:flex; gap:12px; margin-bottom:20px; align-items:end;">
                                <div style="flex:1;">
                                    <label
                                        style="font-size:0.8rem; font-weight:600; color:#666; display:block; margin-bottom:6px;">Dönem
                                        Etiketi</label>
                                    <input type="text" id="ai-week-label" placeholder="Örn: 12 Ocak - 16 Ocak 2026"
                                        style="width:100%; padding:10px; border-radius:10px; border:1px solid #ddd; font-size:0.9rem;">
                                </div>
                                <button class="btn btn-primary" onclick="generateAISummary()"
                                    style="padding:10px 30px; border-radius:12px; white-space:nowrap;">
                                    🤖 Özet Oluştur
                                </button>
                            </div>

                            <!-- AI Metric Cards -->
                            <div id="ai-metric-cards"
                                style="display:none; grid-template-columns:repeat(3, 1fr); gap:12px; margin-bottom:20px;">
                            </div>

                            <!-- AI Özet İçerik -->
                            <div id="ai-summary-content"
                                style="display:none; background:linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color:#e2e8f0; padding:24px; border-radius:16px; font-size:0.9rem; line-height:1.8; white-space:pre-wrap; font-family:'Inter', sans-serif;">
                            </div>

                            <div id="ai-actions" style="display:none; margin-top:15px; display:flex; gap:10px;">
                                <button class="btn btn-outline" onclick="copyAISummary()"
                                    style="padding:8px 20px; font-size:0.85rem;">📋 Kopyala</button>
                                <button class="btn btn-outline" onclick="downloadAISummary()"
                                    style="padding:8px 20px; font-size:0.85rem;">💾 İndir</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== 5. BİLDİRİMLER ===== -->
            <div id="rview-notify" style="display:none;">
                <div style="max-width:900px; margin:0 auto;">
                    <div class="card" style="margin-bottom:20px;">
                        <div class="card-header">🔔 Bildirim Entegrasyonları</div>
                        <div class="card-body">
                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
                                <!-- Slack -->
                                <div style="padding:24px; border:1px solid #e2e8f0; border-radius:16px; text-align:center; transition:all 0.2s;"
                                    onmouseover="this.style.borderColor='#2563eb'; this.style.transform='translateY(-3px)'"
                                    onmouseout="this.style.borderColor='#e2e8f0'; this.style.transform='none'">
                                    <div style="font-size:2.5rem; margin-bottom:12px;">💬</div>
                                    <h3 style="font-size:1.1rem; font-weight:800; margin-bottom:8px;">Slack Entegrasyonu
                                    </h3>
                                    <p style="font-size:0.8rem; color:#64748b; margin-bottom:16px;">Rapor hazır
                                        olduğunda Slack kanalına otomatik bildirim gönderin.</p>
                                    <div style="margin-bottom:12px;">
                                        <input type="text" id="slack-webhook" placeholder="Slack Webhook URL..."
                                            style="width:100%; padding:10px; border-radius:10px; border:1px solid #ddd; font-size:0.8rem;">
                                    </div>
                                    <div style="margin-bottom:12px;">
                                        <input type="text" id="slack-channel" placeholder="#kanal-adı"
                                            value="#pos-raporlar"
                                            style="width:100%; padding:10px; border-radius:10px; border:1px solid #ddd; font-size:0.8rem;">
                                    </div>
                                    <button class="btn btn-primary" onclick="testSlackNotif()"
                                        style="width:100%; border-radius:10px;">
                                        Test Gönder
                                    </button>
                                </div>

                                <!-- Teams -->
                                <div style="padding:24px; border:1px solid #e2e8f0; border-radius:16px; text-align:center; transition:all 0.2s;"
                                    onmouseover="this.style.borderColor='#7c3aed'; this.style.transform='translateY(-3px)'"
                                    onmouseout="this.style.borderColor='#e2e8f0'; this.style.transform='none'">
                                    <div style="font-size:2.5rem; margin-bottom:12px;">🟣</div>
                                    <h3 style="font-size:1.1rem; font-weight:800; margin-bottom:8px;">Teams Entegrasyonu
                                    </h3>
                                    <p style="font-size:0.8rem; color:#64748b; margin-bottom:16px;">Rapor
                                        tamamlandığında Microsoft Teams'e otomatik bildirim gönderin.</p>
                                    <div style="margin-bottom:12px;">
                                        <input type="text" id="teams-webhook" placeholder="Teams Webhook URL..."
                                            style="width:100%; padding:10px; border-radius:10px; border:1px solid #ddd; font-size:0.8rem;">
                                    </div>
                                    <div style="margin-bottom:12px;">
                                        <input type="text" id="teams-channel" placeholder="Kanal Adı"
                                            value="POS Verimlilik"
                                            style="width:100%; padding:10px; border-radius:10px; border:1px solid #ddd; font-size:0.8rem;">
                                    </div>
                                    <button class="btn btn-primary" onclick="testTeamsNotif()"
                                        style="width:100%; border-radius:10px; background:#7c3aed;">
                                        Test Gönder
                                    </button>
                                </div>
                            </div>

                            <!-- Mail Ayarları -->
                            <div
                                style="margin-top:20px; padding:20px; background:#f8fafc; border-radius:16px; border:1px solid #e2e8f0;">
                                <h3 style="font-size:0.95rem; font-weight:700; margin-bottom:12px;">📧 Otomatik Mail
                                    Ayarları</h3>
                                <div style="display:flex; gap:12px; align-items:end;">
                                    <div style="flex:1;">
                                        <label
                                            style="font-size:0.75rem; font-weight:600; color:#64748b; display:block; margin-bottom:4px;">Alıcı
                                            E-posta Adresleri</label>
                                        <input type="text" id="mail-recipients"
                                            placeholder="mail1@firma.com, mail2@firma.com"
                                            style="width:100%; padding:10px; border-radius:10px; border:1px solid #ddd; font-size:0.85rem;">
                                    </div>
                                    <button class="btn btn-outline"
                                        onclick="showNotify('Mail ayarları kaydedildi', 'success')"
                                        style="padding:10px 20px; white-space:nowrap;">💾 Kaydet</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- PAGE: COSTS -->
        <div id="page-costs" class="page-content">
            <h2 class="section-title">Maliyet Analizi</h2>
            <div class="cost-grid" style="max-width:1000px; margin:0 auto 30px;">
                <div class="cost-card">
                    <div class="cost-label">Toplam Gider</div>
                    <div class="cost-value green" id="c-total">$0.00</div>
                </div>
                <div class="cost-card">
                    <div class="cost-label">Token Kullanımı</div>
                    <div class="cost-value blue" id="c-tokens">0</div>
                </div>
                <div class="cost-card">
                    <div class="cost-label">İşlem Sayısı</div>
                    <div class="cost-value purple" id="c-records">0</div>
                </div>
            </div>
            <div class="card" style="max-width:1000px; margin:0 auto;">
                <div class="card-header">Agent Bazlı Harcama</div>
                <div class="card-body">
                    <table style="width:100%; border-collapse:collapse; font-size:0.9rem;">
                        <thead style="background:#f8f9fa;">
                            <tr>
                                <th style="padding:12px; text-align:left; border-bottom:1px solid #eee;">Agent</th>
                                <th style="padding:12px; text-align:center; border-bottom:1px solid #eee;">Çağrı</th>
                                <th style="padding:12px; text-align:right; border-bottom:1px solid #eee;">Maliyet</th>
                            </tr>
                        </thead>
                        <tbody id="cost-table-body"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- PAGE: RESULTS -->
        <div id="page-results" class="page-content">
            <h2 class="section-title">Tamamlanan Görevler</h2>
            <div id="task-list" style="max-width:1000px; margin:0 auto; display:grid; gap:15px;"></div>

            <div id="task-detail" style="display:none; max-width:1000px; margin:20px auto;">
                <div class="card">
                    <div class="card-header">
                        <span id="detail-header">Detay</span>
                        <button class="btn btn-outline" style="padding:4px 12px; font-size:0.75rem;"
                            onclick="closeTaskDetail()">Kapat</button>
                    </div>
                    <div class="card-body">
                        <div id="file-list"
                            style="display:grid; grid-template-columns:repeat(auto-fill, minmax(200px, 1fr)); gap:10px; margin-bottom:20px;">
                        </div>
                        <div id="agent-outputs"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PAGE: TRAINING (Learning Center) -->
        <div id="page-training" class="page-content">
            <h2 class="section-title">Learning Center</h2>
            <p class="section-subtitle">Ajanların uzmanlık verilerini ve kolektif hafızayı yönetin.</p>

            <div id="kb-stats-container"
                style="max-width:1000px; margin:0 auto 30px; display:grid; grid-template-columns:repeat(auto-fit, minmax(250px, 1fr)); gap:20px;">
                <!-- Agent Stats Populated Here -->
            </div>

            <div id="kb-domain-selector"
                style="display:flex; flex-wrap:wrap; gap:10px; justify-content:center; margin-bottom:30px;"></div>

            <div id="kb-files-card" style="display:none; max-width:800px; margin:0 auto;">
                <div class="card">
                    <div class="card-header" id="kb-files-header">Dosyalar</div>
                    <div class="card-body">
                        <div id="kb-file-list" style="display:grid; gap:10px;"></div>
                        <button class="btn btn-primary" onclick="showKBEditor()" style="margin-top:20px;">+ Yeni
                            Dosya</button>
                    </div>
                </div>
            </div>

            <div id="kb-editor-card" style="display:none; max-width:800px; margin:20px auto;">
                <div class="card">
                    <div class="card-header" id="kb-editor-header">Editor</div>
                    <div class="card-body">
                        <input type="text" id="kb-filename" placeholder="Dosya adı..."
                            style="width:100%; padding:10px; margin-bottom:10px; border-radius:8px; border:1px solid #ddd;">
                        <textarea id="kb-content"
                            style="width:100%; height:300px; padding:15px; font-family:monospace; border-radius:8px; border:1px solid #ddd;"></textarea>
                        <div style="display:flex; gap:10px; margin-top:15px;">
                            <button class="btn btn-primary" onclick="saveKBFile()" style="flex:1;">Kaydet</button>
                            <button class="btn btn-outline" onclick="cancelKBEditor()">İptal</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PAGE: SKILLS -->
        <div id="page-skills" class="page-content">
            <h2 class="section-title">Skill Yönetimi</h2>
            <p class="section-subtitle">Agent skill dosyalarını görüntüleyin, düzenleyin ve yönetin.</p>

            <div style="max-width:1200px; margin:0 auto;">
                <!-- Agent-Skill Overview -->
                <div class="card" style="margin-bottom:20px;">
                    <div class="card-header">Agent-Skill Haritası</div>
                    <div class="card-body" id="skill-agent-map"
                        style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:12px;">
                    </div>
                </div>

                <!-- Skill List -->
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
                    <div class="card">
                        <div class="card-header">Skill Dosyaları</div>
                        <div class="card-body" id="skill-list-container" style="max-height:500px; overflow-y:auto;">
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-header">
                            <span id="skill-editor-title">Skill İçeriği</span>
                            <button class="btn btn-primary" id="btn-save-skill" onclick="saveSkill()"
                                style="padding:4px 12px; font-size:0.75rem; display:none;">Kaydet</button>
                        </div>
                        <div class="card-body">
                            <textarea id="skill-editor" placeholder="Bir skill seçin..."
                                style="width:100%; height:400px; padding:15px; border-radius:10px; border:1px solid #ddd; font-family:monospace; font-size:0.8rem; resize:vertical;"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PAGE: PERFORMANCE -->
        <div id="page-performance" class="page-content">
            <h2 class="section-title">Agent Performans Karşılaştırma</h2>
            <p class="section-subtitle">Agent bazında maliyet, token kullanımı ve çalışma istatistikleri.</p>

            <div style="max-width:1200px; margin:0 auto;">
                <!-- Summary Cards -->
                <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:15px; margin-bottom:25px;"
                    id="perf-summary-cards">
                </div>

                <!-- Agent Performance Table -->
                <div class="card">
                    <div class="card-header">Agent Detay Tablosu</div>
                    <div class="card-body" style="overflow-x:auto;">
                        <table style="width:100%; border-collapse:collapse; font-size:0.85rem;" id="perf-table">
                            <thead>
                                <tr style="border-bottom:2px solid #e2e8f0; text-align:left;">
                                    <th style="padding:10px;">Agent</th>
                                    <th style="padding:10px;">Skill</th>
                                    <th style="padding:10px;">Domain</th>
                                    <th style="padding:10px; text-align:right;">Çalışma</th>
                                    <th style="padding:10px; text-align:right;">Token</th>
                                    <th style="padding:10px; text-align:right;">Maliyet</th>
                                    <th style="padding:10px;">Verimlilik</th>
                                </tr>
                            </thead>
                            <tbody id="perf-table-body"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- PAGE: PROJECTS -->
        <div id="page-projects" class="page-content">
            <h2 class="section-title">Proje Galerisi</h2>
            <p class="section-subtitle">AI Agent'ların oluşturduğu tüm projeleri görüntüleyin, test edin ve kaynak
                kodlarını inceleyin.</p>

            <!-- Summary -->
            <div style="max-width:1200px; margin:0 auto 30px;">
                <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:15px;" id="proj-summary-cards">
                </div>
            </div>

            <!-- Project Grid -->
            <div class="projects-grid" id="projects-grid"></div>
        </div>

    </main>

    <!-- PROJECT DETAIL OVERLAY -->
    <div id="proj-detail-overlay" class="proj-detail-overlay">
        <div class="proj-detail-panel">
            <div class="proj-detail-header">
                <h3 id="proj-detail-title">Proje Detayı</h3>
                <div style="display:flex; gap:8px; align-items:center;">
                    <span id="proj-detail-badge" class="proj-badge"></span>
                    <button class="btn btn-outline" style="padding:6px 16px; font-size:0.8rem; border-radius:10px;"
                        onclick="closeProjectDetail()">✕ Kapat</button>
                </div>
            </div>
            <div class="proj-detail-body">
                <div class="proj-file-list" id="proj-file-list"></div>
                <div class="proj-preview-area">
                    <div class="proj-preview-tabs">
                        <div class="proj-preview-tab active" id="ptab-preview" onclick="switchProjectView('preview')">
                            Önizleme</div>
                        <div class="proj-preview-tab" id="ptab-code" onclick="switchProjectView('code')">Kaynak Kod
                        </div>
                    </div>
                    <div class="proj-preview-content" id="proj-preview-content">
                        <iframe id="proj-iframe" src="about:blank"></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL: CODE VIEWER -->
    <div id="code-modal"
        style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:2000; align-items:center; justify-content:center;">
        <div class="card" style="width:90%; height:80%; max-width:1100px; display:flex; flex-direction:column;">
            <div class="card-header">
                <span id="modal-filename">Dosya İçeriği</span>
                <button class="btn btn-outline" style="padding:4px 12px; font-size:0.75rem;"
                    onclick="closeCodeModal()">Kapat</button>
            </div>
            <div class="card-body" style="flex:1; overflow:hidden; padding:0;">
                <pre id="modal-content"
                    style="width:100%; height:100%; margin:0; padding:20px; overflow:auto; background:#1e1e1e; color:#d1d5db; font-family:monospace; font-size:0.85rem; line-height:1.6;"></pre>
            </div>
        </div>
    </div>

    <script>
        // ===== STATE =====
        let selectedDomain = null;
        let currentTeamAgents = [];
        let allDomains = [];
        let domainAgents = {};
        let passedAgents = new Set();
        let lastAgent = null;
        let savedTeam = null;

        // ===== NOTIFICATIONS =====
        function showNotify(message, type = 'info') {
            const container = document.getElementById('notification-container');
            const toast = document.createElement('div');
            toast.className = `notification-toast ${type}`;

            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };

            toast.innerHTML = `
                <span class="icon">${icons[type] || 'ℹ️'}</span>
                <div class="message">${message}</div>
                <span class="close-btn" onclick="this.parentElement.remove()">&times;</span>
            `;

            container.appendChild(toast);

            // Auto remove
            setTimeout(() => {
                toast.style.animation = 'fadeOutUp 0.4s ease forwards';
                setTimeout(() => toast.remove(), 400);
            }, 4000);
        }

        // ===== TAB SWITCHING =====
        function switchTab(tabId) {
            // UI Updates
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.getElementById('tab-' + tabId).classList.add('active');

            document.querySelectorAll('.page-content').forEach(p => p.classList.remove('active'));
            const page = document.getElementById('page-' + tabId);
            if (page) page.classList.add('active');

            // Hide hero if not domains
            document.getElementById('dashboard-hero').style.display = (tabId === 'domains') ? 'block' : 'none';

            // Data Loading
            if (tabId === 'builder') {
                if (!selectedDomain) {
                    // Domain seçilmemişse domains sayfasına yönlendir
                    switchTab('domains');
                    showNotify('Lütfen önce bir iş alanı seçin.', 'warning');
                    return;
                }

                // Eğer agent verisi dizi olarak yüklenmediyse (örneğin sekmeye doğrudan tıklandıysa)
                if (!Array.isArray(domainAgents)) {
                    selectDomain();
                    return;
                }

                renderAgentPool();
                renderTeamLineup();
            }
            if (tabId === 'results') loadTaskResults();
            if (tabId === 'costs') loadCosts();
            if (tabId === 'training') loadTrainingData();
            if (tabId === 'reports') switchReportView('weekly');
            if (tabId === 'skills') loadSkillsPage();
            if (tabId === 'performance') loadPerformancePage();
            if (tabId === 'projects') loadProjectsPage();

            // Scroll to top
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // ===== DOMAINS =====
        async function loadDomains() {
            try {
                const res = await fetch('/api/domains');
                allDomains = await res.json();
                const grid = document.getElementById('domain-grid');
                grid.innerHTML = allDomains.map(d => `
                    <div class="domain-card" data-id="${d.id}" onclick="pickDomain('${d.id}')">
                        <span class="domain-icon">${d.icon}</span>
                        <div class="domain-name">${d.name}</div>
                        <div class="domain-desc">${d.description}</div>
                        <div class="domain-meta">
                            <span>👥 ${d.agent_count} Agent</span>
                        </div>
                    </div>
                `).join('');
            } catch (e) { console.error(e); }
        }

        function pickDomain(id) {
            if (selectedDomain !== id) {
                selectedDomain = id;
                domainAgents = {}; // Yeni alan seçildiğinde eski takım listesini sıfırla ki fetch tetiklenebilsin
            }
            document.querySelectorAll('.domain-card').forEach(c => {
                c.classList.toggle('selected', c.getAttribute('data-id') === id);
            });
            document.getElementById('btn-select-domain').disabled = false;
        }

        async function selectDomain() {
            if (!selectedDomain) return;
            const res = await fetch(`/api/domains/${selectedDomain}/agents`);
            domainAgents = await res.json();

            const domain = allDomains.find(d => d.id === selectedDomain);
            document.getElementById('builder-title').innerText = `${domain.icon} ${domain.name} Yapılandırması`;

            const dRes = await fetch(`/api/domains/${selectedDomain}`);
            const full = await dRes.json();
            currentTeamAgents = [...full.default_team];

            renderAgentPool();
            renderTeamLineup();
            switchTab('builder');
        }

        // ===== BUILDER =====
        function renderAgentPool() {
            const pool = document.getElementById('agent-pool');
            pool.innerHTML = domainAgents.map(a => {
                const inTeam = currentTeamAgents.includes(a.id);
                return `
                    <div class="agent-chip ${inTeam ? 'in-team' : ''}">
                        <div style="font-size:1.2rem;">${a.icon}</div>
                        <div style="flex:1;">
                            <div style="font-weight:600; font-size:0.85rem;">${a.name}</div>
                            <div style="font-size:0.75rem; color:#888;">${a.role}</div>
                        </div>
                        <button class="btn btn-outline" style="padding:4px 10px; font-size:0.7rem;" onclick="toggleAgent('${a.id}')">
                            ${inTeam ? 'Sıra Dışı' : 'Ekle'}
                        </button>
                    </div>
                `;
            }).join('');
        }

        function toggleAgent(id) {
            const idx = currentTeamAgents.indexOf(id);
            if (idx > -1) currentTeamAgents.splice(idx, 1);
            else currentTeamAgents.push(id);
            renderAgentPool();
            renderTeamLineup();
        }

        function renderTeamLineup() {
            const lineup = document.getElementById('team-lineup');
            let totalCost = 0;
            lineup.innerHTML = currentTeamAgents.map((aid, i) => {
                const a = domainAgents.find(x => x.id === aid);
                if (!a) return '';
                totalCost += a.cost_per_hour;
                return `
                    <div style="display:flex; align-items:center; gap:10px; padding:10px; border-bottom:1px solid #eee;">
                        <span style="font-size:0.7rem; color:#ccc;">#${i + 1}</span>
                        <span>${a.icon}</span>
                        <span style="font-weight:600; font-size:0.85rem;">${a.name}</span>
                    </div>
                `;
            }).join('');
            document.getElementById('summary-cost').innerText = `$${totalCost}/saat`;
        }

        async function createTeam() {
            const name = document.getElementById('team-name').value || `Takım-${Date.now()}`;
            const res = await fetch('/api/teams', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, domain_id: selectedDomain, agents: currentTeamAgents, agent_order: currentTeamAgents })
            });
            if (res.ok) {
                savedTeam = await res.json();
                document.getElementById('task-runner-section').style.display = 'block';
                document.getElementById('btn-create-team').innerText = '✅ Takım Hazır';
            }
        }

        async function runTask() {
            const task = document.getElementById('task-input').value;
            const btn = document.getElementById('btn-run-task');
            btn.disabled = true;
            try {
                const res = await fetch(`/api/teams/${savedTeam.id}/run`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ task })
                });
                if (res.ok) {
                    switchTab('monitor');
                }
            } catch (e) { console.error(e); btn.disabled = false; }
        }

        // ===== MONITORING =====
        function updateMonitoring() {
            fetch('/api/status').then(r => r.json()).then(data => {
                const agent = data.agent || "Idle";
                const isIdle = agent === "Idle";

                document.getElementById('header-status').innerText = isIdle ? "Sistem Hazır" : agent + " Çalışıyor";
                document.getElementById('m-agent').innerText = agent;
                document.getElementById('m-task').innerText = data.task || "-";

                const logW = document.getElementById('log-window');
                if (data.logs && data.logs.length > 0) {
                    logW.innerHTML = data.logs.map(log => {
                        const m = log.match(/\[([^\]]+)\]\s*(.*)/);
                        const isErr = log.includes('❌');
                        const isOk = log.includes('✅');
                        return `<div class="log-line ${isErr ? 'error' : ''} ${isOk ? 'success' : ''}">
                            <span class="time">${m ? '[' + m[1] + ']' : ''}</span>
                            <span class="message">${m ? m[2] : log}</span>
                        </div>`;
                    }).join('');
                    logW.scrollTop = logW.scrollHeight;
                }
            }).catch(() => {
                document.getElementById('header-status').innerText = "Bağlantı Kaybı";
            });
        }

        // ===== REPORTS =====
        function switchReportView(viewId) {
            // Update buttons
            document.querySelectorAll('[id^="rtab-"]').forEach(b => b.classList.replace('btn-primary', 'btn-outline'));
            document.getElementById('rtab-' + viewId).classList.replace('btn-outline', 'btn-primary');

            // Update views
            document.querySelectorAll('[id^="rview-"]').forEach(v => v.style.display = 'none');
            document.getElementById('rview-' + viewId).style.display = 'block';

            if (viewId === 'monthly') loadReportDomains();
            if (viewId === 'trends') loadBQTrends();
        }

        async function loadReportDomains() {
            const res = await fetch('/api/berqun/domains');
            const data = await res.json();
            const list = document.getElementById('report-domain-list');
            list.innerHTML = data.domains.map(d => `
                <label style="display:flex; align-items:center; gap:8px; cursor:pointer; font-size:0.85rem;">
                    <input type="checkbox" name="report-domain" value="${d}"> ${d}
                </label>
            `).join('');
        }

        function toggleReportDomains(checked) {
            document.querySelectorAll('input[name="report-domain"]').forEach(cb => cb.checked = checked);
        }

        function updateReportDates() {
            const m = document.getElementById('report-month-select').value;
            const y = document.getElementById('report-year-select').value;
            const monthNames = ["Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran", "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık"];
            document.getElementById('date-preview').innerText = `${monthNames[m - 1]} ${y} Raporu`;
            return {
                start_date: `${y}-${m.padStart(2, '0')}-01`,
                month_label: `${monthNames[m - 1]} ${y}`,
                month_en: `${monthNames[m - 1]}_${y}`,
                report_date: `${y}-${m.padStart(2, '0')}-01`
            };
        }

        async function runBatchReports() {
            const checkboxes = document.querySelectorAll('input[name="report-domain"]:checked');
            const domains = Array.from(checkboxes).map(cb => cb.value);
            if (domains.length === 0) { showNotify('Lütfen en az bir domain seçin!', 'warning'); return; }

            const m = document.getElementById('report-month-select').value;
            const y = document.getElementById('report-year-select').value;
            const monthNames = ["Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran", "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık"];

            const payload = {
                domains,
                month_label: `${monthNames[m - 1]} ${y}`,
                month_en: `${monthNames[m - 1]}_${y}`,
                start_date: `${y}-${m.padStart(2, '0')}-01`,
                end_date: new Date(y, m, 0).toISOString().split('T')[0],
                report_date: `${y}-${m.padStart(2, '0')}-01`
            };

            const res = await fetch('/api/berqun/run_batch', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            if (res.ok) {
                document.getElementById('report-status-badge').innerText = "Çalışıyor...";
                showNotify("Rapor işlemi başarıyla başlatıldı.", 'success');
            }
        }

        // --- Weekly Reports ---
        async function runWeeklyPOS() {
            const start = document.getElementById('wp-start').value;
            const end = document.getElementById('wp-end').value;
            const noMail = document.getElementById('wp-nomail').checked;
            const team = document.getElementById('wp-team').value;

            if (!start || !end) {
                showNotify('Haftalık rapor için başlangıç ve bitiş tarihleri gereklidir!', 'warning');
                return;
            }

            const btn = document.getElementById('btn-run-weekly');
            btn.disabled = true;
            btn.innerText = "⏳ Çalıştırılıyor...";

            const payload = { week_start: start, week_end: end, no_mail: noMail };
            if (team) payload.team = team;

            try {
                const res = await fetch('/api/berqun/weekly_pos', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (res.ok) {
                    const teamLabel = team || 'Tüm Ekipler';
                    showNotify(`Haftalık rapor başlatıldı: ${teamLabel}`, 'success');
                    document.getElementById('wp-status-indicator').innerText = "Çalışıyor...";
                    document.getElementById('wp-status-indicator').style.background = "#dcfce7";
                    document.getElementById('wp-status-indicator').style.color = "#166534";
                }
            } catch (e) {
                showNotify('Rapor başlatılamadı: ' + e, 'error');
                btn.disabled = false;
                btn.innerText = "📊 Haftalık Raporu Başlat";
            }
        }

        // --- AI Summary ---
        async function generateAISummary() {
            const weekLabel = document.getElementById('ai-week-label').value || "Son Hafta";
            showNotify('AI Özet oluşturuluyor, lütfen bekleyin...', 'info');

            try {
                const res = await fetch('/api/berqun/ai_summary', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ week_label: weekLabel })
                });
                const data = await res.json();

                if (data.error) throw new Error(data.error);

                // Render metrics
                const metricCont = document.getElementById('ai-metric-cards');
                metricCont.style.display = 'grid';
                metricCont.innerHTML = [
                    { label: 'AVG BQ', value: data.metrics.avg_bq, color: '#2563eb' },
                    { label: 'LOW BQ', value: data.metrics.low_bq_count, color: '#dc2626' },
                    { label: 'MAX BQ', value: data.metrics.max_bq, color: '#16a34a' }
                ].map(m => `
                    <div style="background:#f8fafc; padding:15px; border-radius:12px; border:1px solid #e2e8f0; text-align:center;">
                        <div style="font-size:0.7rem; color:#888; font-weight:700;">${m.label}</div>
                        <div style="font-size:1.2rem; font-weight:800; color:${m.color};">${m.value}</div>
                    </div>
                `).join('');

                const summaryCont = document.getElementById('ai-summary-content');
                summaryCont.style.display = 'block';
                summaryCont.innerText = data.summary;

                document.getElementById('ai-actions').style.display = 'flex';
                showNotify('AI Özet başarıyla oluşturuldu.', 'success');
            } catch (e) {
                showNotify('AI Özet hatası: ' + e.message, 'error');
            }
        }

        function copyAISummary() {
            const text = document.getElementById('ai-summary-content').innerText;
            navigator.clipboard.writeText(text);
            showNotify('AI Özet panoya kopyalandı.', 'success');
        }

        // --- BQ Trends ---
        async function loadBQTrends() {
            const container = document.getElementById('bq-trend-body');
            container.innerHTML = '<tr><td colspan="8" style="text-align:center; padding:40px;">⏳ Veriler çekiliyor...</td></tr>';

            try {
                const res = await fetch('/api/berqun/bq_trends');
                const data = await res.json();

                if (data.error) throw new Error(data.error);

                // Improving
                document.getElementById('bq-improving').innerHTML = (data.improving || []).map(t => `
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:10px; border-bottom:1px solid #f1f5f9;">
                        <div>
                            <div style="font-weight:700; font-size:0.85rem;">${t.name}</div>
                            <div style="font-size:0.7rem; color:#888;">${t.team}</div>
                        </div>
                        <div style="text-align:right;">
                            <div style="color:#16a34a; font-weight:800; font-size:0.9rem;">+${t.change}</div>
                            <div style="font-size:0.7rem; color:#ccc;">BQ: ${t.latest_bq}</div>
                        </div>
                    </div>
                `).join('');

                // Declining
                document.getElementById('bq-declining').innerHTML = (data.declining || []).map(t => `
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:10px; border-bottom:1px solid #f1f5f9;">
                        <div>
                            <div style="font-weight:700; font-size:0.85rem;">${t.name}</div>
                            <div style="font-size:0.7rem; color:#888;">${t.team}</div>
                        </div>
                        <div style="text-align:right;">
                            <div style="color:#dc2626; font-weight:800; font-size:0.9rem;">${t.change}</div>
                            <div style="font-size:0.7rem; color:#ccc;">BQ: ${t.latest_bq}</div>
                        </div>
                    </div>
                `).join('');

                // Table
                container.innerHTML = data.trends.map(t => {
                    const sparkHtml = t.weeks.map(w => {
                        const h = w ? Math.min(w / 1.5, 100) : 0;
                        const color = w >= 100 ? '#16a34a' : '#f59e0b';
                        return `<div style="width:4px; height:${h}px; background:${color}; border-radius:2px;"></div>`;
                    }).join('');

                    return `
                        <tr style="border-bottom:1px solid #f1f5f9;">
                            <td style="padding:10px; font-weight:600;">${t.name}</td>
                            <td style="padding:10px; color:#666;">${t.team}</td>
                            ${t.weeks.map(w => `<td style="padding:10px; text-align:center; font-weight:700;">${w || '-'}</td>`).join('')}
                            <td style="padding:10px; text-align:center; font-weight:800; color:${t.change >= 0 ? '#16a34a' : '#dc2626'}">
                                ${t.change > 0 ? '+' : ''}${t.change}
                            </td>
                            <td style="padding:10px;">
                                <div style="display:flex; align-items:flex-end; gap:2px; height:20px;">${sparkHtml}</div>
                            </td>
                        </tr>
                    `;
                }).join('');

                document.getElementById('bq-total-badge').innerText = `${data.total_staff} Personel Listelendi`;

            } catch (e) {
                showNotify('Trend verisi yüklenemedi: ' + e.message, 'error');
                container.innerHTML = '<tr><td colspan="8" style="text-align:center; padding:40px; color:#dc2626;">⚠️ Hata oluştu</td></tr>';
            }
        }

        // --- Mock Notifications ---
        function testSlackNotif() {
            const url = document.getElementById('slack-webhook').value;
            if (!url) { showNotify('Lütfen önce Webhook URL girin', 'warning'); return; }
            showNotify('Slack test bildirimi gönderiliyor...', 'info');
            setTimeout(() => showNotify('Slack bildirimi başarıyla gönderildi (Simüle edildi)', 'success'), 1500);
        }

        function testTeamsNotif() {
            const url = document.getElementById('teams-webhook').value;
            if (!url) { showNotify('Lütfen önce Webhook URL girin', 'warning'); return; }
            showNotify('Teams test bildirimi gönderiliyor...', 'info');
            setTimeout(() => showNotify('Teams bildirimi başarıyla gönderildi (Simüle edildi)', 'success'), 1500);
        }

        // ===== COSTS =====
        async function loadCosts() {
            const res = await fetch('/api/costs');
            const data = await res.json();
            document.getElementById('c-total').innerText = `$${data.total_cost_usd.toFixed(2)}`;
            document.getElementById('c-tokens').innerText = data.total_tokens.toLocaleString();
            document.getElementById('c-records').innerText = data.total_records;

            const tbody = document.getElementById('cost-table-body');
            tbody.innerHTML = (data.agents || []).map(a => `
                <tr>
                    <td style="padding:10px;">${a.agent_name}</td>
                    <td style="padding:10px;text-align:center;">${a.total_calls}</td>
                    <td style="padding:10px;text-align:right;font-weight:700;">$${a.total_cost_usd.toFixed(4)}</td>
                </tr>
            `).join('');
        }

        // ===== RESULTS =====
        async function loadTaskResults() {
            const res = await fetch('/api/tasks');
            const tasks = await res.json();
            const list = document.getElementById('task-list');
            list.innerHTML = tasks.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp)).map(t => `
                <div class="card" onclick="viewTaskDetail('${t.task_id}')" style="cursor:pointer; transition:all 0.2s;">
                    <div class="card-body" style="display:flex; justify-content:space-between; align-items:center;">
                        <div>
                            <div style="font-weight:700; color:#111;">${t.task_description}</div>
                            <div style="font-size:0.75rem; color:#888; margin-top:5px;">
                                👥 ${t.team_name} · ⏰ ${new Date(t.timestamp).toLocaleString()}
                            </div>
                        </div>
                        <span style="font-size:1.2rem; color:#ccc;">→</span>
                    </div>
                </div>
            `).join('');
        }

        async function viewTaskDetail(id) {
            const res = await fetch(`/api/tasks/${id}`);
            const data = await res.json();
            const detailDiv = document.getElementById('task-detail');
            detailDiv.style.display = 'block';
            document.getElementById('detail-header').innerText = `📂 ${data.task_description}`;

            // File List with Code Viewer triggers
            const fileList = document.getElementById('file-list');
            fileList.innerHTML = (data.generated_files || []).map(f => `
                <div onclick="viewFileContent('${id}', '${f.filename}')" style="
                    padding:12px; background:#f8f9fa; border:1px solid #eee; border-radius:10px; 
                    font-size:0.8rem; cursor:pointer; display:flex; align-items:center; gap:8px;
                    transition:all 0.2s;
                " onmouseover="this.style.borderColor='var(--rd-blue)'" onmouseout="this.style.borderColor='#eee'">
                    <span style="font-size:1.1rem;">📄</span>
                    <div style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${f.filename}</div>
                </div>
            `).join('');

            // Agent Outputs
            document.getElementById('agent-outputs').innerHTML = (data.outputs || []).map(o => `
                <div style="margin-top:20px;">
                    <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px;">
                        <span style="font-weight:700; font-size:0.85rem; color:var(--rd-blue);">${o.agent_name}</span>
                        <hr style="flex:1; border:none; border-top:1px solid #eee;">
                    </div>
                    <pre style="font-size:0.8rem; background:#fdfdfd; border:1px solid #f0f0f0; padding:15px; border-radius:10px; white-space:pre-wrap; color:#444;">${o.output}</pre>
                </div>
            `).join('');

            detailDiv.scrollIntoView({ behavior: 'smooth' });
        }

        function closeTaskDetail() {
            document.getElementById('task-detail').style.display = 'none';
        }

        async function viewFileContent(taskId, filename) {
            try {
                const res = await fetch(`/api/tasks/${taskId}/files/${filename}`);
                const data = await res.json();
                document.getElementById('modal-filename').innerText = `📄 ${filename}`;
                document.getElementById('modal-content').innerText = data.content;
                document.getElementById('code-modal').style.display = 'flex';
                document.body.style.overflow = 'hidden';
            } catch (e) {
                showNotify('Dosya içeriği yüklenemedi.', 'error');
            }
        }

        function closeCodeModal() {
            document.getElementById('code-modal').style.display = 'none';
            document.body.style.overflow = 'auto';
        }

        // ===== TRAINING (Learning Center) =====
        let selectedKBDomain = null;
        async function loadTrainingData() {
            const statsRes = await fetch('/api/knowledge/stats');
            const stats = await statsRes.json();

            // Restore Agent Definition Stats
            const statsCont = document.getElementById('kb-stats-container');
            const domains = Object.keys(stats.domains);
            statsCont.innerHTML = domains.map(dName => {
                const d = stats.domains[dName];
                return `
                    <div class="cost-card" style="text-align:left;">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px;">
                             <div class="cost-label">${dName} Uzmanlığı</div>
                             <span style="font-size:1.2rem;">${d.file_count > 0 ? '🧠' : '🌑'}</span>
                        </div>
                        <div style="font-weight:800; font-size:1.4rem; color:var(--rd-blue);">${d.file_count} <span style="font-size:0.8rem; color:#888;">Doküman</span></div>
                        <div style="font-size:0.75rem; color:#aaa; margin-top:8px;">
                            ${(d.total_chars / 1024).toFixed(1)} KB Eğitim Verisi
                        </div>
                    </div>
                `;
            }).join('');

            const selector = document.getElementById('kb-domain-selector');
            selector.innerHTML = Object.keys(stats.domains).map(d => `
                <button class="btn btn-outline" onclick="selectKBDomain('${d}')">${d}</button>
            `).join('');
        }

        async function selectKBDomain(id) {
            selectedKBDomain = id;
            const res = await fetch(`/api/knowledge/${id}`);
            const files = await res.json();
            document.getElementById('kb-files-card').style.display = 'block';
            document.getElementById('kb-file-list').innerHTML = files.map(f => `
                <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 18px; background:#f8f9fa; border:1px solid #eee; border-radius:12px;">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <span style="color:var(--rd-blue);">📄</span>
                        <span style="font-size:0.85rem; font-weight:600;">${f.filename}</span>
                    </div>
                    <div style="display:flex; gap:8px;">
                        <button class="btn btn-outline" style="padding:4px 12px; font-size:0.75rem;" onclick="editKBFile('${id}','${f.filename}')">Düzenle</button>
                    </div>
                </div>
            `).join('');
            document.getElementById('kb-files-card').scrollIntoView({ behavior: 'smooth' });
        }

        function showKBEditor() { document.getElementById('kb-editor-card').style.display = 'block'; document.getElementById('kb-editor-card').scrollIntoView({ behavior: 'smooth' }); }
        function cancelKBEditor() { document.getElementById('kb-editor-card').style.display = 'none'; }

        async function editKBFile(did, fn) {
            const res = await fetch(`/api/knowledge/${did}/${fn}`);
            const data = await res.json();
            document.getElementById('kb-filename').value = fn;
            document.getElementById('kb-content').value = data.content;
            showKBEditor();
        }

        async function saveKBFile() {
            const filename = document.getElementById('kb-filename').value;
            const content = document.getElementById('kb-content').value;
            if (!filename || !content) { showNotify('İsim ve içerik gerekli!', 'warning'); return; }

            await fetch(`/api/knowledge/${selectedKBDomain}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ filename, content })
            });
            showNotify('Dosya başarıyla kaydedildi.', 'success');
            cancelKBEditor();
            selectKBDomain(selectedKBDomain);
        }

        // ===== SKILL MANAGEMENT =====
        let currentEditingSkill = null;

        async function loadSkillsPage() {
            try {
                // Agent-Skill haritası
                const overviewRes = await fetch('/api/agents/skills-overview');
                const overview = await overviewRes.json();
                const mapEl = document.getElementById('skill-agent-map');
                mapEl.innerHTML = overview.map(a => {
                    const hasSkill = a.skill_loaded;
                    const bg = hasSkill ? '#f0fdf4' : '#fef2f2';
                    const border = hasSkill ? '#86efac' : '#fca5a5';
                    const badge = hasSkill
                        ? `<span style="background:#22c55e; color:#fff; padding:2px 8px; border-radius:4px; font-size:0.7rem;">${a.skill}</span>`
                        : `<span style="background:#ef4444; color:#fff; padding:2px 8px; border-radius:4px; font-size:0.7rem;">Skill Yok</span>`;
                    return `
                        <div style="display:flex; align-items:center; gap:10px; padding:10px; border-radius:8px; background:${bg}; border:1px solid ${border};">
                            <span style="font-size:1.3rem;">${a.agent_icon}</span>
                            <div style="flex:1;">
                                <div style="font-weight:600; font-size:0.85rem;">${a.agent_name}</div>
                                <div style="font-size:0.7rem; color:#888;">${a.domain_name}</div>
                            </div>
                            ${badge}
                        </div>`;
                }).join('');

                // Skill listesi
                const skillsRes = await fetch('/api/skills');
                const skills = await skillsRes.json();
                const listEl = document.getElementById('skill-list-container');
                listEl.innerHTML = skills.map(s => `
                    <div onclick="editSkill('${s.name}')" style="display:flex; align-items:center; gap:10px; padding:12px; border-bottom:1px solid #eee; cursor:pointer; transition:background 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                        <div style="flex:1;">
                            <div style="font-weight:600; font-size:0.85rem;">${s.title || s.name}</div>
                            <div style="font-size:0.7rem; color:#888;">${s.filename} - ${s.lines} satır - ${(s.size / 1024).toFixed(1)}KB</div>
                        </div>
                        <span style="background:#e0e7ff; color:#4338ca; padding:2px 8px; border-radius:4px; font-size:0.7rem;">${s.agent_count} agent</span>
                    </div>
                `).join('');
            } catch (e) { console.error(e); }
        }

        async function editSkill(skillName) {
            try {
                const res = await fetch(`/api/skills/${skillName}`);
                const data = await res.json();
                document.getElementById('skill-editor').value = data.content;
                document.getElementById('skill-editor-title').innerText = `${skillName}.md`;
                document.getElementById('btn-save-skill').style.display = 'inline-block';
                currentEditingSkill = skillName;
            } catch (e) { console.error(e); }
        }

        async function saveSkill() {
            if (!currentEditingSkill) return;
            const content = document.getElementById('skill-editor').value;
            try {
                const res = await fetch(`/api/skills/${currentEditingSkill}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content })
                });
                if (res.ok) {
                    showNotify(`${currentEditingSkill} skill başarıyla güncellendi!`, 'success');
                }
            } catch (e) { console.error(e); }
        }

        // ===== PERFORMANCE =====
        async function loadPerformancePage() {
            try {
                const res = await fetch('/api/performance/agents');
                const agents = await res.json();

                // Summary cards
                const totalRuns = agents.reduce((s, a) => s + a.total_runs, 0);
                const totalCost = agents.reduce((s, a) => s + a.total_cost_usd, 0);
                const totalTokens = agents.reduce((s, a) => s + a.total_input_tokens + a.total_output_tokens, 0);
                const activeAgents = agents.length;

                document.getElementById('perf-summary-cards').innerHTML = [
                    { label: 'Aktif Agent', value: activeAgents, color: '#818cf8' },
                    { label: 'Toplam Çalışma', value: totalRuns, color: '#22c55e' },
                    { label: 'Toplam Token', value: totalTokens.toLocaleString(), color: '#f59e0b' },
                    { label: 'Toplam Maliyet', value: `$${totalCost.toFixed(4)}`, color: '#ef4444' }
                ].map(c => `
                    <div style="background:#fff; border-radius:12px; padding:20px; border-left:4px solid ${c.color}; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
                        <div style="font-size:0.75rem; color:#888; text-transform:uppercase;">${c.label}</div>
                        <div style="font-size:1.5rem; font-weight:700; margin-top:5px;">${c.value}</div>
                    </div>
                `).join('');

                // Table
                const tbody = document.getElementById('perf-table-body');
                if (agents.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="7" style="padding:30px; text-align:center; color:#888;">Henüz agent performans verisi yok. Bir takım çalıştırın.</td></tr>';
                    return;
                }

                // Sort by cost desc
                agents.sort((a, b) => b.total_cost_usd - a.total_cost_usd);

                tbody.innerHTML = agents.map(a => {
                    const tokens = a.total_input_tokens + a.total_output_tokens;
                    const costPerRun = a.total_runs > 0 ? (a.total_cost_usd / a.total_runs) : 0;
                    const efficiency = costPerRun < 0.001 ? 'Yüksek' : costPerRun < 0.005 ? 'Orta' : 'Düşük';
                    const effColor = costPerRun < 0.001 ? '#22c55e' : costPerRun < 0.005 ? '#f59e0b' : '#ef4444';
                    return `
                        <tr style="border-bottom:1px solid #f1f5f9;">
                            <td style="padding:10px;">
                                <span style="margin-right:6px;">${a.agent_icon || '🤖'}</span>
                                <strong>${a.agent_name}</strong>
                            </td>
                            <td style="padding:10px;">
                                ${a.skill ? `<span style="background:#e0e7ff; color:#4338ca; padding:2px 6px; border-radius:4px; font-size:0.7rem;">${a.skill}</span>` : '-'}
                            </td>
                            <td style="padding:10px; font-size:0.8rem; color:#666;">${a.domain || '-'}</td>
                            <td style="padding:10px; text-align:right; font-weight:600;">${a.total_runs}</td>
                            <td style="padding:10px; text-align:right;">${tokens.toLocaleString()}</td>
                            <td style="padding:10px; text-align:right; font-weight:600;">$${a.total_cost_usd.toFixed(4)}</td>
                            <td style="padding:10px;">
                                <span style="background:${effColor}20; color:${effColor}; padding:3px 8px; border-radius:4px; font-size:0.75rem; font-weight:600;">${efficiency}</span>
                            </td>
                        </tr>`;
                }).join('');
            } catch (e) { console.error(e); }
        }

        // ===== PROJECTS PAGE =====
        let currentProject = null;
        let currentProjectView = 'preview';

        async function loadProjectsPage() {
            try {
                const res = await fetch('/api/projects');
                const projects = await res.json();

                // Summary cards
                const totalFiles = projects.reduce((s, p) => s + p.file_count, 0);
                const totalSize = projects.reduce((s, p) => s + p.total_size, 0);
                const types = {};
                projects.forEach(p => { types[p.type] = (types[p.type] || 0) + 1; });
                const mainType = Object.entries(types).sort((a, b) => b[1] - a[1])[0];

                document.getElementById('proj-summary-cards').innerHTML = [
                    { label: 'TOPLAM PROJE', value: projects.length, color: 'blue' },
                    { label: 'TOPLAM DOSYA', value: totalFiles, color: 'green' },
                    { label: 'TOPLAM BOYUT', value: formatBytes(totalSize), color: 'purple' },
                    { label: 'ANA TİP', value: mainType ? mainType[0].toUpperCase() : '-', color: 'green' }
                ].map(c => `
                    <div class="cost-card">
                        <div class="cost-label">${c.label}</div>
                        <div class="cost-value ${c.color}">${c.value}</div>
                    </div>
                `).join('');

                // Project cards
                const grid = document.getElementById('projects-grid');
                if (projects.length === 0) {
                    grid.innerHTML = `<div style="text-align:center; grid-column:1/-1; padding:60px 20px; color:#94a3b8;">
                        <div style="font-size:3rem; margin-bottom:16px;">📂</div>
                        <div style="font-size:1.1rem; font-weight:600;">Henüz proje oluşturulmamış</div>
                        <div style="font-size:0.9rem; margin-top:8px;">Trello Orchestrator çalıştırarak ilk projenizi oluşturun.</div>
                    </div>`;
                    return;
                }

                grid.innerHTML = projects.map(p => {
                    const fileChips = p.files.map(f =>
                        `<span class="proj-file-chip"><span class="dot ${f.language}"></span>${f.name}</span>`
                    ).join('');

                    return `
                    <div class="project-card" onclick="openProjectDetail('${p.name}')">
                        <div class="proj-header">
                            <div class="proj-name">${p.display_name}</div>
                            <span class="proj-badge ${p.type}">${p.type}</span>
                        </div>
                        <div class="proj-files">${fileChips}</div>
                        <div class="proj-meta">
                            <span>📄 ${p.file_count} dosya</span>
                            <span>📦 ${formatBytes(p.total_size)}</span>
                        </div>
                        <div class="proj-actions">
                            <button class="btn-proj primary" onclick="event.stopPropagation(); openProjectPreview('${p.name}')">
                                ▶ Önizle
                            </button>
                            <button class="btn-proj" onclick="event.stopPropagation(); openProjectDetail('${p.name}')">
                                📄 Kaynak Kod
                            </button>
                        </div>
                    </div>`;
                }).join('');

            } catch (e) { console.error(e); }
        }

        function formatBytes(bytes) {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const sizes = ['B', 'KB', 'MB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
        }

        async function openProjectDetail(projectName) {
            try {
                const res = await fetch('/api/projects');
                const projects = await res.json();
                currentProject = projects.find(p => p.name === projectName);
                if (!currentProject) return;

                document.getElementById('proj-detail-title').textContent = currentProject.display_name;
                const badge = document.getElementById('proj-detail-badge');
                badge.textContent = currentProject.type;
                badge.className = 'proj-badge ' + currentProject.type;

                // File list
                const fileList = document.getElementById('proj-file-list');
                fileList.innerHTML = currentProject.files.map((f, i) => `
                    <div class="proj-file-item ${i === 0 ? 'active' : ''}" onclick="selectProjectFile('${projectName}', '${f.name}', this)">
                        <span class="dot ${f.language}"></span>
                        ${f.name}
                        <span class="file-size">${formatBytes(f.size)}</span>
                    </div>
                `).join('');

                // Default: preview
                switchProjectView('preview');
                document.getElementById('proj-iframe').src = '/api/projects/' + projectName + '/preview';

                document.getElementById('proj-detail-overlay').classList.add('active');
            } catch (e) { console.error(e); }
        }

        function closeProjectDetail() {
            document.getElementById('proj-detail-overlay').classList.remove('active');
            document.getElementById('proj-iframe').src = 'about:blank';
            currentProject = null;
        }

        function openProjectPreview(projectName) {
            openProjectDetail(projectName);
        }

        function switchProjectView(view) {
            currentProjectView = view;
            document.getElementById('ptab-preview').classList.toggle('active', view === 'preview');
            document.getElementById('ptab-code').classList.toggle('active', view === 'code');

            const content = document.getElementById('proj-preview-content');
            const iframe = document.getElementById('proj-iframe');

            if (view === 'preview') {
                content.innerHTML = '';
                content.appendChild(iframe);
                iframe.style.display = 'block';
                if (currentProject) {
                    iframe.src = '/api/projects/' + currentProject.name + '/preview';
                }
            } else {
                // Show code of first file
                if (currentProject && currentProject.files.length > 0) {
                    selectProjectFile(currentProject.name, currentProject.files[0].name, null);
                }
            }
        }

        async function selectProjectFile(projectName, filename, el) {
            // Active state
            if (el) {
                document.querySelectorAll('.proj-file-item').forEach(e => e.classList.remove('active'));
                el.classList.add('active');
            }

            try {
                const res = await fetch(`/api/projects/${projectName}/files/${filename}`);
                const data = await res.json();

                // Switch to code view
                document.getElementById('ptab-preview').classList.remove('active');
                document.getElementById('ptab-code').classList.add('active');
                currentProjectView = 'code';

                const content = document.getElementById('proj-preview-content');
                const lines = data.content.split('\n');
                const numbered = lines.map((line, i) =>
                    `<span style="color:#858585; margin-right:16px; user-select:none;">${String(i + 1).padStart(4)}</span>${escapeHtml(line)}`
                ).join('\n');

                content.innerHTML = `<pre>${numbered}</pre>`;
            } catch (e) { console.error(e); }
        }

        function escapeHtml(text) {
            const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
            return text.replace(/[&<>"']/g, m => map[m]);
        }

        // Close overlay on Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeProjectDetail();
        });

        // ===== INIT =====
        loadDomains();
        setInterval(updateMonitoring, 3000);
        setInterval(() => {
            const reportPage = document.getElementById('page-reports');
            if (reportPage && reportPage.classList.contains('active')) {
                fetch('/api/status').then(r => r.json()).then(data => {
                    // Monthly report logs
                    const berqunLogs = (data.logs || []).filter(l => l.includes('[BERQUN]') && !l.includes('[BERQUN-WEEKLY]')).join('\n');
                    const logContainer = document.getElementById('report-logs');
                    if (berqunLogs && logContainer) logContainer.innerText = berqunLogs;

                    // Weekly POS report logs
                    const weeklyLogs = (data.logs || []).filter(l => l.includes('[BERQUN-WEEKLY]')).join('\n');
                    const wpLogContainer = document.getElementById('wp-live-logs');
                    if (weeklyLogs && wpLogContainer) {
                        wpLogContainer.innerText = weeklyLogs;
                        wpLogContainer.scrollTop = wpLogContainer.scrollHeight;
                    }

                    // Re-enable button if task completed
                    const task = data.task || '';
                    const btn = document.getElementById('btn-run-weekly');
                    const indicator = document.getElementById('wp-status-indicator');
                    if (task.includes('Tamamlandı') || task.includes('Hata') || data.agent === 'Idle' || data.agent === 'Error') {
                        if (btn && btn.disabled) {
                            btn.disabled = false;
                            btn.innerText = '📊 Haftalık Raporu Başlat';
                        }
                        if (indicator && task.includes('Tamamlandı')) {
                            indicator.innerText = 'Tamamlandı ✅';
                            indicator.style.background = '#dcfce7';
                            indicator.style.color = '#166534';
                        } else if (indicator && data.agent === 'Error') {
                            indicator.innerText = 'Hata ❌';
                            indicator.style.background = '#fef2f2';
                            indicator.style.color = '#dc2626';
                        }
                    }
                });
            }
        }, 2000);
    </script>
</body>

</html>